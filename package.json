{
  "name": "nws-discord",
  "version": "1.0.0",
  "description": "Nice Wolf Studio Discord notification service - centralized Discord gateway API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/db/schema.sql dist/db/",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp/server.js",
    "mcp:dev": "tsx src/mcp/server.ts"
  },
  "keywords": [
    "discord",
    "api",
    "mcp",
    "notification"
  ],
  "author": "Nice Wolf Studio",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.2.0",
    "better-sqlite3": "^11.6.0",
    "discord.js": "^14.14.1",
    "dotenv": "^17.3.1",
    "hono": "^4.6.12",
    "nanoid": "^5.0.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
