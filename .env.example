# Required
DISCORD_TOKEN=your-bot-token-here
ADMIN_API_KEY=generate-a-secure-key

# DM allowlist (comma-separated Discord user IDs)
ALLOWED_DM_USERS=

# Optional
PORT=3000
DATABASE_PATH=./data/nws-discord.db
LOG_LEVEL=info
DEDUP_WINDOW_SECONDS=300

# For MCP clients
NWS_DISCORD_API_KEY=your-client-api-key
