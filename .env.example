# ============================================
# Required
# ============================================

# Anthropic API key for AI responses
ANTHROPIC_API_KEY=sk-ant-...

# Admin API key for webhook endpoints
ADMIN_API_KEY=generate-a-secure-key

# DM allowlist - admin user IDs (comma-separated Discord user IDs)
ALLOWED_DM_USERS=

# ============================================
# Discord Bot Tokens (per personality)
# ============================================

# Sombra - Admin bot (required)
SOMBRA_DISCORD_TOKEN=your-sombra-bot-token

# Princess Donut (optional - skipped if missing)
DONUT_DISCORD_TOKEN=your-donut-bot-token

# Mordecai (optional - skipped if missing)
MORDECAI_DISCORD_TOKEN=your-mordecai-bot-token

# ============================================
# Optional
# ============================================

PORT=3000
DATABASE_PATH=./data/nws-discord.db
LOG_LEVEL=info
DEDUP_WINDOW_SECONDS=300

# For MCP clients
NWS_DISCORD_API_KEY=your-client-api-key

# ============================================
# Removed (no longer needed)
# ============================================
# SOMBRA_AI_URL - now uses direct Anthropic SDK
# DONUT_AI_URL - now uses direct Anthropic SDK
